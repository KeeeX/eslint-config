{
  "allowScripts": {
    "unrs-resolver": false
  },
  "author": "KeeeX SAS",
  "bin": {
    "kxeslint-dump": "src/bin/kxeslint-dump.js",
    "kxeslint-setup": "src/bin/kxeslint-setup.js"
  },
  "cleanPublish": {
    "behavior": {
      "cleanPrepack": {
        "README.md": {
          "remove": [
            "https://devtools.keeex.me",
            "https://devtools.keeex.net",
            "https://sast.keeex.net",
            "https://forge.keeex.net",
            "https://cicd.keeex.net",
            "https://docs.keeex.me"
          ],
          "type": "text"
        },
        "package.json": {
          "add": {
            "homepage": "https://keeex.me/oss"
          },
          "remove": [
            "repository"
          ],
          "type": "json"
        },
        "sonar-project.properties": "remove"
      },
      "cleanPublish": {
        "package.json": {
          "package": true,
          "remove": [
            "repository"
          ],
          "type": "json"
        }
      },
      "cleanSource": {
        "README.md": {
          "remove": [
            "https://devtools.keeex.me",
            "https://devtools.keeex.net",
            "https://sast.keeex.net",
            "https://forge.keeex.net",
            "https://cicd.keeex.net",
            "https://docs.keeex.me"
          ],
          "type": "text"
        },
        "package.json": {
          "add": {
            "homepage": "https://keeex.me/oss",
            "scripts": {
              "build": "tslib build",
              "check": "tslib check",
              "clean": "tslib clean",
              "prepack": "npm run clean && npm run build",
              "test": "tslib test"
            }
          },
          "remove": [
            "repository",
            "cleanPublish"
          ],
          "type": "json"
        },
        "sonar-project.properties": "remove"
      }
    }
  },
  "contributors": [
    {
      "email": "gabriel@keeex.net",
      "name": "Gabriel Paul \"Cley Faye\" Risterucci"
    }
  ],
  "dependencies": {
    "prompts": "^2.4.2",
    "semver": "^7.8.5"
  },
  "description": "Common eslint configuration",
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.2",
    "@keeex/clean-publish": "^1.4.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-mocha": "^11.3.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1"
  },
  "exports": {
    ".": "./src/index.js",
    "./prettier.config.js": "./prettier.config.js"
  },
  "files": [
    "prettier.config.js",
    "src"
  ],
  "license": "MIT",
  "name": "@keeex/eslint-config",
  "peerDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "9.x",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "3.x || 4.x",
    "eslint-plugin-import-x": "4.x",
    "eslint-plugin-mocha": "10.x || >11.0.0",
    "eslint-plugin-promise": "7.x",
    "eslint-plugin-react": "7.x",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-tsdoc": "0.x",
    "globals": "16.x || 17.x",
    "prettier": "3.x",
    "typescript-eslint": "8.x"
  },
  "peerDependenciesMeta": {
    "@eslint/compat": {
      "optional": true
    },
    "eslint": {
      "optional": false
    },
    "eslint-import-resolver-typescript": {
      "optional": true
    },
    "eslint-import-resolver-webpack": {
      "optional": true
    },
    "eslint-plugin-deprecation": {
      "optional": true
    },
    "eslint-plugin-import-x": {
      "optional": true
    },
    "eslint-plugin-mocha": {
      "optional": true
    },
    "eslint-plugin-promise": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "eslint-plugin-tsdoc": {
      "optional": true
    },
    "globals": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "typescript-eslint": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KeeeX/eslint-config.git"
  },
  "scripts": {
    "bin:dump": "node src/bin/kxeslint-dump.js",
    "bin:setup": "node src/bin/kxeslint-setup.js",
    "check": "npx eslint --cache --cache-strategy content .",
    "clean": "echo Nothing to clean",
    "postpack": "clean-publish restore",
    "prepack": "clean-publish cleanPublish",
    "prepublishOnly": "publish_check",
    "test": "echo No test for this project"
  },
  "type": "module",
  "version": "2.7.0"
}
